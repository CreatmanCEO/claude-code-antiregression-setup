{
  "permissions": {
    "allow": [
      "Bash(python -m pytest*)",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(npx *)",
      "Bash(pip install*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(make*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[HOOK] Running tests before commit...' && python -m pytest tests/ -x --timeout=60 2>&1 | tail -30 || (echo '{\"block\": true, \"message\": \"Tests are failing. Fix all test failures before committing.\"}' 1>&2 && exit 2)",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[HOOK] File modified. Remember: run tests before committing.'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
